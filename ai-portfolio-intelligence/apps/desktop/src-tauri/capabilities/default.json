{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal capability for the bundled Portfolio Analyzer UI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "args": false,
          "name": "binaries/portfolio-api",
          "sidecar": true
        }
      ]
    }
  ]
}
