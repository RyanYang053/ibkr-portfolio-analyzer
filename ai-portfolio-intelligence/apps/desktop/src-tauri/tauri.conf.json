{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Portfolio Analyzer",
  "version": "0.1.0",
  "identifier": "com.portfolioanalyzer.desktop",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": null,
    "beforeBuildCommand": "python3 ../../scripts/prepare-tauri-binaries.py --skip-web-build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/henry.w@example.net",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/portfolio-api"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [],
      "pubkey": ""
    }
  }
}
