# Default engineering mode uses Postgres. Desktop installers use SQLite instead.
DEPLOYMENT_MODE=development
DATABASE_URL=postgresql+psycopg://portfolio:portfolio@localhost:5432/portfolio
PERSISTENCE_BACKEND=postgres
JWT_SECRET=change-me
BROKER_MODE=ibkr_readonly

# Auth bootstrap and registration (development / hosted only — not used by desktop_local)
BOOTSTRAP_TOKEN=
ALLOW_PUBLIC_REGISTRATION=false
DISABLE_AUTH_ENFORCEMENT=false
ACCESS_TOKEN_HOURS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Desktop local (set by Tauri sidecar launcher; do not use for public servers) ---
# DEPLOYMENT_MODE=desktop_local
# PERSISTENCE_BACKEND=sqlite
# DATABASE_URL=sqlite+pysqlite:////absolute/path/to/portfolio.db
# LOCAL_API_HOST=127.0.0.1
# LOCAL_API_PORT=49182
# LOCAL_SESSION_TOKEN=<per-launch-token-min-43-chars>
# DISABLE_AUTH_ENFORCEMENT=true

# Optional explicit demo mode only:
# BROKER_MODE=mock_ibkr_readonly

# IBKR Flex Query (optional) for deposits, withdrawals, dividends, and corporate actions.
# In desktop builds, prefer OS Keychain storage over this env var.
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
IBKR_FLEX_ACTIVITY_QUERY_ID=
# Annual risk-free rate for Sharpe/Sortino/CAPM (decimal, e.g. 0.04 for 4%).
RISK_FREE_RATE_ANNUAL=0
# Enable only after walk-forward score calibration validates predictive skill.
ENABLE_STRONG_ADD_RECOMMENDATIONS=false
GEMINI_MODEL=gemini-2.5-flash
AI_TIMEOUT_SECONDS=35
