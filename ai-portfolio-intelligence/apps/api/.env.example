DATABASE_URL=postgresql+psycopg://portfolio:portfolio@localhost:5432/portfolio
JWT_SECRET=change-me
BROKER_MODE=ibkr_readonly

# Auth bootstrap and registration
BOOTSTRAP_TOKEN=
ALLOW_PUBLIC_REGISTRATION=false
DISABLE_AUTH_ENFORCEMENT=false
ACCESS_TOKEN_HOURS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Optional explicit demo mode only:
# BROKER_MODE=mock_ibkr_readonly

# IBKR Flex Query (optional) for deposits, withdrawals, dividends, and corporate actions.
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
IBKR_FLEX_ACTIVITY_QUERY_ID=
# Annual risk-free rate for Sharpe/Sortino/CAPM (decimal, e.g. 0.04 for 4%).
RISK_FREE_RATE_ANNUAL=0
# Enable only after walk-forward score calibration validates predictive skill.
ENABLE_STRONG_ADD_RECOMMENDATIONS=false
GEMINI_MODEL=gemini-2.5-flash
AI_TIMEOUT_SECONDS=35
