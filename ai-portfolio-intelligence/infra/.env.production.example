# Production environment template. Copy to .env and fill in strong values.
ENVIRONMENT=production
PERSISTENCE_BACKEND=postgres
POSTGRES_PASSWORD=replace-with-strong-password
JWT_SECRET=replace-with-long-random-secret
BOOTSTRAP_TOKEN=replace-with-one-time-bootstrap-token
GEMINI_API_KEY=
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
IBKR_FLEX_ACTIVITY_QUERY_ID=
BROKER_MODE=ibkr_readonly
DISABLE_AUTH_ENFORCEMENT=false
DISABLE_AUTH_MIDDLEWARE=false
